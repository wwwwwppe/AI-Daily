# ── Email Delivery ──────────────────────────────────────────────────────────────
# Choose one backend: "smtp" or "sendgrid"
EMAIL_BACKEND=smtp

# SMTP settings (used when EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# SendGrid API key (used when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity
EMAIL_FROM_NAME=AI日报
EMAIL_FROM_ADDRESS=ai-daily@example.com
EMAIL_SUBJECT=【AI日报】{date} 今日科技与AI精选

# ── Recipients ───────────────────────────────────────────────────────────────────
# Comma-separated list of recipient addresses
# (alternatively, populate config/recipients.txt, one address per line)
EMAIL_RECIPIENTS=employee1@example.com,employee2@example.com

# ── Optional: Twitter / X API v2 ────────────────────────────────────────────────
# Required to fetch tweets from AI influencers.
# Apply for access at https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── Proxy (optional) ────────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── Report Window (optional) ─────────────────────────────────────────────────────
# REPORT_WINDOW_MODE:
# - anchored: [yesterday REPORT_WINDOW_HOUR:00, today REPORT_WINDOW_HOUR:00)
# - rolling:  [now-24h, now)  (recommended for ad-hoc my-news generation)
REPORT_WINDOW_MODE=rolling
# Anchored mode only: pull items from [yesterday REPORT_WINDOW_HOUR:00, today REPORT_WINDOW_HOUR:00)
REPORT_WINDOW_HOUR=8
# Timezone offset used by report window calculations (e.g. UTC+8 => 8)
REPORT_WINDOW_TZ_OFFSET=8

# ── Translation (optional) ───────────────────────────────────────────────────────
# Add Chinese translation line for English-only content
ENABLE_ENGLISH_TRANSLATION=true
# Translation endpoint (Google public translate API-compatible)
TRANSLATE_API_URL=https://translate.googleapis.com/translate_a/single

# ── DeepSeek (optional, for --mode my-news) ─────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# For GLM Anthropic-compatible API, you can use:
# DEEPSEEK_API_URL=https://open.bigmodel.cn/api/anthropic
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60
# Optional override. 0 = auto by provider (GLM Anthropic defaults to 131072)
MY_NEWS_MAX_TOKENS=0
# Required marker for my-news output validation
MY_NEWS_REQUIRED_MARKER=- 导读 -
# Wait/retry guard: if marker missing, keep retrying until timeout (seconds)
MY_NEWS_MAX_WAIT_SECONDS=600
MY_NEWS_RETRY_INTERVAL_SECONDS=20
# Developer alert recipients when marker is still missing at timeout
DEVELOPER_ALERT_RECIPIENTS=dev1@example.com,dev2@example.com
MY_NEWS_PRUNE_INVALID_SOURCE_ITEMS=false
