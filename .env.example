# ── Email Delivery ──────────────────────────────────────────────────────────────
# Choose one backend: "smtp" or "sendgrid"
EMAIL_BACKEND=smtp

# SMTP settings (used when EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# SendGrid API key (used when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity
EMAIL_FROM_NAME=AI日报
EMAIL_FROM_ADDRESS=ai-daily@example.com
EMAIL_SUBJECT=【AI日报】{date} 今日科技与AI精选

# ── Recipients ───────────────────────────────────────────────────────────────────
# Comma-separated list of recipient addresses
# (alternatively, populate config/recipients.txt, one address per line)
EMAIL_RECIPIENTS=employee1@example.com,employee2@example.com

# ── Optional: Twitter / X API v2 ────────────────────────────────────────────────
# Required to fetch tweets from AI influencers.
# Apply for access at https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── Proxy (optional) ────────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
